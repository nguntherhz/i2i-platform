{
  "base_url": "https://t3a5h65dejiqek-8188.proxy.runpod.net",
  "local_url": "http://localhost:8188",

  "endpoints": {
    "system_stats": {
      "method": "GET",
      "path": "/api/system_stats",
      "description": "Check system status, VRAM usage, ComfyUI version"
    },
    "upload_image": {
      "method": "POST",
      "path": "/upload/image",
      "content_type": "multipart/form-data",
      "description": "Upload an image for processing",
      "fields": {
        "image": "(binary file)",
        "type": "input",
        "overwrite": "true"
      }
    },
    "queue_prompt": {
      "method": "POST",
      "path": "/api/prompt",
      "content_type": "application/json",
      "description": "Queue a workflow for execution",
      "body": {
        "prompt": "<workflow_json>",
        "client_id": "<optional_client_id>"
      }
    },
    "get_history": {
      "method": "GET",
      "path": "/api/history/{prompt_id}",
      "description": "Get execution result and output filenames"
    },
    "view_image": {
      "method": "GET",
      "path": "/view?filename={filename}&type=output",
      "description": "Download output image or video"
    },
    "free_memory": {
      "method": "POST",
      "path": "/api/free",
      "content_type": "application/json",
      "description": "Free VRAM and unload models",
      "body": {
        "unload_models": true,
        "free_memory": true
      }
    },
    "get_queue": {
      "method": "GET",
      "path": "/api/queue",
      "description": "Check current queue status"
    }
  }
}
