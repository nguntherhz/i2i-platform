{
  "description": "Template I2I con LoRA intercambiable por categoría. Reemplazar {{VARIABLES}} antes de enviar a POST /api/prompt",

  "categories": {
    "face_consistency": {
      "lora": "Qwen-Image-Edit-F2P.safetensors",
      "strength_model": 0.7,
      "strength_clip": 0.7,
      "description": "Mantiene consistencia facial al transformar. Ideal para cambios de ropa/escena donde la cara debe ser idéntica."
    },
    "none": {
      "lora": null,
      "description": "Sin LoRA. Usa el modelo base directamente. Para generación T2I o cambios donde no importa la consistencia facial."
    }
  },

  "note": "Para agregar más LoRAs: descargar el .safetensors a models/loras/ en el pod, y agregar una nueva categoría acá con el nombre del archivo.",

  "template_with_lora": {
    "prompt": {
      "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
          "ckpt_name": "Qwen-Rapid-AIO-NSFW-v18.1.safetensors"
        }
      },
      "10": {
        "class_type": "LoraLoader",
        "inputs": {
          "model": ["1", 0],
          "clip": ["1", 1],
          "lora_name": "{{LORA_NAME}}",
          "strength_model": "{{LORA_STRENGTH_MODEL}}",
          "strength_clip": "{{LORA_STRENGTH_CLIP}}"
        }
      },
      "7": {
        "class_type": "LoadImage",
        "inputs": {
          "image": "{{INPUT_IMAGE}}",
          "upload": "image"
        }
      },
      "3": {
        "class_type": "TextEncodeQwenImageEditPlus",
        "inputs": {
          "clip": ["10", 1],
          "vae": ["1", 2],
          "prompt": "{{POSITIVE_PROMPT}}",
          "image1": ["7", 0]
        }
      },
      "4": {
        "class_type": "TextEncodeQwenImageEditPlus",
        "inputs": {
          "clip": ["10", 1],
          "vae": ["1", 2],
          "prompt": "{{NEGATIVE_PROMPT}}"
        }
      },
      "9": {
        "class_type": "EmptyLatentImage",
        "inputs": {
          "width": "{{WIDTH}}",
          "height": "{{HEIGHT}}",
          "batch_size": 1
        }
      },
      "2": {
        "class_type": "KSampler",
        "inputs": {
          "model": ["10", 0],
          "positive": ["3", 0],
          "negative": ["4", 0],
          "latent_image": ["9", 0],
          "seed": "{{SEED}}",
          "steps": "{{STEPS}}",
          "cfg": 1.0,
          "sampler_name": "euler_ancestral",
          "scheduler": "beta",
          "denoise": "{{DENOISE}}"
        }
      },
      "5": {
        "class_type": "VAEDecode",
        "inputs": {
          "samples": ["2", 0],
          "vae": ["1", 2]
        }
      },
      "6": {
        "class_type": "SaveImage",
        "inputs": {
          "images": ["5", 0],
          "filename_prefix": "{{OUTPUT_PREFIX}}"
        }
      }
    }
  },

  "template_without_lora": {
    "prompt": {
      "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
          "ckpt_name": "Qwen-Rapid-AIO-NSFW-v18.1.safetensors"
        }
      },
      "7": {
        "class_type": "LoadImage",
        "inputs": {
          "image": "{{INPUT_IMAGE}}",
          "upload": "image"
        }
      },
      "3": {
        "class_type": "TextEncodeQwenImageEditPlus",
        "inputs": {
          "clip": ["1", 1],
          "vae": ["1", 2],
          "prompt": "{{POSITIVE_PROMPT}}",
          "image1": ["7", 0]
        }
      },
      "4": {
        "class_type": "TextEncodeQwenImageEditPlus",
        "inputs": {
          "clip": ["1", 1],
          "vae": ["1", 2],
          "prompt": "{{NEGATIVE_PROMPT}}"
        }
      },
      "9": {
        "class_type": "EmptyLatentImage",
        "inputs": {
          "width": "{{WIDTH}}",
          "height": "{{HEIGHT}}",
          "batch_size": 1
        }
      },
      "2": {
        "class_type": "KSampler",
        "inputs": {
          "model": ["1", 0],
          "positive": ["3", 0],
          "negative": ["4", 0],
          "latent_image": ["9", 0],
          "seed": "{{SEED}}",
          "steps": "{{STEPS}}",
          "cfg": 1.0,
          "sampler_name": "euler_ancestral",
          "scheduler": "beta",
          "denoise": "{{DENOISE}}"
        }
      },
      "5": {
        "class_type": "VAEDecode",
        "inputs": {
          "samples": ["2", 0],
          "vae": ["1", 2]
        }
      },
      "6": {
        "class_type": "SaveImage",
        "inputs": {
          "images": ["5", 0],
          "filename_prefix": "{{OUTPUT_PREFIX}}"
        }
      }
    }
  },

  "example_request_with_lora": {
    "prompt": {
      "1": {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "Qwen-Rapid-AIO-NSFW-v18.1.safetensors"}},
      "10": {"class_type": "LoraLoader", "inputs": {"model": ["1", 0], "clip": ["1", 1], "lora_name": "Qwen-Image-Edit-F2P.safetensors", "strength_model": 0.7, "strength_clip": 0.7}},
      "7": {"class_type": "LoadImage", "inputs": {"image": "mi_foto.png", "upload": "image"}},
      "3": {"class_type": "TextEncodeQwenImageEditPlus", "inputs": {"clip": ["10", 1], "vae": ["1", 2], "prompt": "The same woman at a beach wearing white bikini, same face same eyes same skin, photorealistic, full body", "image1": ["7", 0]}},
      "4": {"class_type": "TextEncodeQwenImageEditPlus", "inputs": {"clip": ["10", 1], "vae": ["1", 2], "prompt": "different face, different person, deformed, bad anatomy, blurry, low quality, watermark"}},
      "9": {"class_type": "EmptyLatentImage", "inputs": {"width": 768, "height": 1024, "batch_size": 1}},
      "2": {"class_type": "KSampler", "inputs": {"model": ["10", 0], "positive": ["3", 0], "negative": ["4", 0], "latent_image": ["9", 0], "seed": 0, "steps": 8, "cfg": 1.0, "sampler_name": "euler_ancestral", "scheduler": "beta", "denoise": 0.65}},
      "5": {"class_type": "VAEDecode", "inputs": {"samples": ["2", 0], "vae": ["1", 2]}},
      "6": {"class_type": "SaveImage", "inputs": {"images": ["5", 0], "filename_prefix": "i2i_lora"}}
    }
  },

  "example_request_without_lora": {
    "prompt": {
      "1": {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "Qwen-Rapid-AIO-NSFW-v18.1.safetensors"}},
      "7": {"class_type": "LoadImage", "inputs": {"image": "mi_foto.png", "upload": "image"}},
      "3": {"class_type": "TextEncodeQwenImageEditPlus", "inputs": {"clip": ["1", 1], "vae": ["1", 2], "prompt": "The same woman at a beach wearing white bikini, same face same eyes same skin, photorealistic, full body", "image1": ["7", 0]}},
      "4": {"class_type": "TextEncodeQwenImageEditPlus", "inputs": {"clip": ["1", 1], "vae": ["1", 2], "prompt": "different face, different person, deformed, bad anatomy, blurry, low quality, watermark"}},
      "9": {"class_type": "EmptyLatentImage", "inputs": {"width": 768, "height": 1024, "batch_size": 1}},
      "2": {"class_type": "KSampler", "inputs": {"model": ["1", 0], "positive": ["3", 0], "negative": ["4", 0], "latent_image": ["9", 0], "seed": 0, "steps": 8, "cfg": 1.0, "sampler_name": "euler_ancestral", "scheduler": "beta", "denoise": 0.72}},
      "5": {"class_type": "VAEDecode", "inputs": {"samples": ["2", 0], "vae": ["1", 2]}},
      "6": {"class_type": "SaveImage", "inputs": {"images": ["5", 0], "filename_prefix": "i2i_base"}}
    }
  }
}
